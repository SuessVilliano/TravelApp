# --- Supabase (optional) ---
# Leave these BLANK to run the app in local demo mode (data stored in your
# browser's localStorage). Fill them in to switch to a real Supabase backend.
#
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Copy your project URL + anon key below
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI provider (optional) ---
# Powers the AI Trip Planner + Concierge. Leave BLANK to use smart built-in
# fallbacks (app stays fully functional). Set ONE of these to go live.
# Anthropic is preferred when both are present.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
